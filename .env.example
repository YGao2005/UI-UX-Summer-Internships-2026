# UI/UX Internship Scraper - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================================================
# OPTIONAL API KEYS (Scraper works without these, but fewer results)
# ============================================================================

# The Muse API Key
# Sign up at: https://www.themuse.com/developers/api/v2
# Free tier: 3,600 requests/hour
# Provides: Design internship listings with explicit category filter
THEMUSE_API_KEY=your_themuse_api_key_here

# Adzuna API Credentials
# Sign up at: https://developer.adzuna.com/
# Free tier: 1,000 calls/month (~33/day)
# Provides: Broad coverage of UI/UX internship postings
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Jooble API Key
# Sign up at: https://jooble.org/api/about
# Free tier: Rate limits TBD (check documentation)
# Provides: Job aggregator with explicit internship category
JOOBLE_API_KEY=your_jooble_api_key_here

# ============================================================================
# NOTES
# ============================================================================
# - Without API keys: Scraper uses 4 sources (Greenhouse, Lever, Ashby, RemoteOK)
# - With API keys: Scraper uses 7 sources (adds The Muse + Adzuna + Jooble)
# - Expected results:
#   * Without keys: 5-15 internships
#   * With keys: 30-100+ internships
#
# - These keys are also used in GitHub Actions (set in GitHub Secrets)
# - Never commit your .env file to git (.gitignore excludes it)
